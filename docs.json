{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "CamposCloud",
  "colors": {
    "primary": "#2464ec",
    "light": "#2464ec",
    "dark": "#2464ec"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "index",
              "quickstart",
              "development"
            ]
          }
        ]
      },
      {
        "tab": "API reference",
        "groups": [
          {
            "group": "API documentation",
            "pages": [
              "api-reference/authentication",
              "api-reference/api-limits"
            ]
          },
          {
            "group": "API Endpoint",
            "tag": "endpoint",
            "pages": [
              {
                "group": "User",
                "pages": [
                  "api-reference/endpoint/v1/users/@me"
                ]
              },
              {
                "group": "Applications",
                "pages": [
                  "api-reference/endpoint/v1/applications/appId",
                  "api-reference/endpoint/v1/applications/create"
                ]
              }
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Website",
          "href": "https://camposcloud.com",
          "icon": "book-open-cover"
        },
        {
          "anchor": "Discord Community",
          "href": "https://dicord.gg/camposcloud",
          "icon": "discord"
        },
        {
          "anchor": "Status page",
          "href": "https://status.camposcloud.com",
          "icon": "heart-pulse"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "https://discord.gg/camposcloud"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://camposcloud.com/dashboard/applications"
    }
  },
  "footer": {
    "socials": {
      "x": "https://x.com/mintlify",
      "github": "https://github.com/mintlify",
      "linkedin": "https://linkedin.com/company/mintlify"
    }
  }
}